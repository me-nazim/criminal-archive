# ==========================================================
# Tansiq Information Portal - Environment Variables (sample)
# Copy this file to `.env` and fill in real values.
# ==========================================================

# ----- App -----
APP_ENV=development
APP_PORT=8080
APP_BASE_URL=http://localhost:8080
FRONTEND_BASE_URL=http://localhost:5173

# ----- Database (PostgreSQL 18) -----
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=tansiq
POSTGRES_USER=tansiq
POSTGRES_PASSWORD=change-me-strong-password
DATABASE_URL=postgres://tansiq:change-me-strong-password@postgres:5432/tansiq?sslmode=disable

# ----- Auth -----
JWT_SECRET=replace-with-a-long-random-string-min-32-chars
JWT_ISSUER=tansiq
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h
BCRYPT_COST=12
COOKIE_SECURE=false
COOKIE_DOMAIN=

# ----- Object Storage (Cloudflare R2 / S3-compatible) -----
# Locally we use MinIO; in prod point these to R2.
S3_ENDPOINT=http://minio:9000
S3_REGION=auto
S3_ACCESS_KEY=minio-access
S3_SECRET_KEY=minio-secret-change-me
S3_BUCKET=tansiq-archive
S3_PUBLIC_BASE_URL=http://localhost:9000/tansiq-archive
S3_FORCE_PATH_STYLE=true

# ----- CORS -----
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ----- Rate limiting -----
RATE_LIMIT_RPS=20
RATE_LIMIT_BURST=40

# ----- Logging -----
LOG_LEVEL=info
LOG_FORMAT=json
