# ==========================================================
# Tansiq Information Portal - Environment Variables (sample)
# Copy this file to `.env` and fill in real values.
#
# Most provider config (storage, email, branding) now lives in the
# database (`app_settings`) and is editable from the admin UI at
# /admin/settings. Only the bootstrap variables below need to be set
# in env files.
# ==========================================================

# ----- App -----
APP_ENV=development
APP_PORT=8080
APP_BASE_URL=http://localhost:8080
FRONTEND_BASE_URL=http://localhost:5173

# ----- Database (PostgreSQL 18) -----
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=tansiq
POSTGRES_USER=tansiq
POSTGRES_PASSWORD=change-me-strong-password
DATABASE_URL=postgres://tansiq:change-me-strong-password@postgres:5432/tansiq?sslmode=disable

# ----- Auth -----
JWT_SECRET=replace-with-a-long-random-string-min-32-chars
JWT_ISSUER=tansiq
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h
BCRYPT_COST=12
COOKIE_SECURE=false
COOKIE_DOMAIN=

# ----- Settings encryption key -----
# Used to encrypt secret fields (SMTP/Resend/Elastic Email API keys,
# storage secret keys, etc.) at rest in the `app_settings` table.
# Required for production. At least 16 characters; 32+ recommended.
APP_SETTINGS_KEY=replace-with-a-long-random-string-32-chars-min

# ----- Object Storage bootstrap (optional) -----
# These are only consulted on the *first* boot. After that, storage is
# managed at /admin/settings/storage. Leave empty to configure entirely
# from the admin UI. We default the local dev compose to MinIO.
S3_ENDPOINT=http://minio:9000
S3_REGION=auto
S3_ACCESS_KEY=minio-access
S3_SECRET_KEY=minio-secret-change-me
S3_BUCKET=tansiq-archive
S3_PUBLIC_BASE_URL=http://localhost:9000/tansiq-archive
S3_FORCE_PATH_STYLE=true

# ----- CORS -----
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ----- Rate limiting -----
RATE_LIMIT_RPS=20
RATE_LIMIT_BURST=40

# ----- Logging -----
LOG_LEVEL=info
LOG_FORMAT=json
