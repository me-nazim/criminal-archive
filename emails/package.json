    "build": "npm run export"
  },
  "dependencies": {
    "@react-email/components": "^0.0.31",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "react-email": "^3.0.4"
  }
}
